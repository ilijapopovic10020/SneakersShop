<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SneakersShop.MVVM.Views.FinishOrderPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
    xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:model="clr-namespace:SneakersShop.MVVM.Models"
    xmlns:viewmodel="clr-namespace:SneakersShop.MVVM.ViewModels"
    x:DataType="viewmodel:CreateOrderViewModel"
    BackgroundColor="{AppThemeBinding Light={StaticResource White},
                                      Dark={StaticResource Gray950}}"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">
    <ContentPage.BindingContext>
        <viewmodel:CreateOrderViewModel />
    </ContentPage.BindingContext>
    <Grid RowDefinitions="auto, auto, auto, auto, *" RowSpacing="25">
        <Border
            Grid.Row="0"
            Margin="10"
            Background="{StaticResource Gray100}"
            HeightRequest="40"
            HorizontalOptions="Start"
            StrokeShape="RoundRectangle 20"
            StrokeThickness="0"
            VerticalOptions="Start"
            WidthRequest="40">
            <Image
                Aspect="AspectFit"
                HeightRequest="20"
                Source="back.svg"
                StyleClass="ElevatedButton"
                WidthRequest="20">
                <Image.Behaviors>
                    <mct:IconTintColorBehavior TintColor="Black" />
                </Image.Behaviors>
            </Image>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="Back_TapGestureRecognizer_Tapped" />
            </Border.GestureRecognizers>
        </Border>


        <Border
            Grid.Row="1"
            Padding="10,0"
            BackgroundColor="{StaticResource Gray100}"
            HeightRequest="44"
            StrokeShape="RoundRectangle 30"
            StrokeThickness="0"
            WidthRequest="380">
            <Grid Padding="10" ColumnDefinitions="*,*">
                <Button
                    x:Name="CardButton"
                    Command="{Binding SelectPaymentCommand}"
                    CommandParameter="{x:Static model:PaymentType.Card}"
                    HeightRequest="35"
                    Text="{Binding PaymentOptions[0].DisplayName}"
                    TextColor="Black">
                    <Button.Triggers>
                        <DataTrigger
                            Binding="{Binding SelectedPaymentType}"
                            TargetType="Button"
                            Value="{x:Static model:PaymentType.Card}">
                            <Setter Property="BackgroundColor" Value="White" />
                            <Setter Property="TextColor" Value="Black" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding SelectedPaymentType}"
                            TargetType="Button"
                            Value="{x:Static model:PaymentType.COD}">
                            <Setter Property="BackgroundColor" Value="Transparent" />
                            <Setter Property="TextColor" Value="{StaticResource Gray400}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button
                    x:Name="CodButton"
                    Grid.Column="1"
                    Command="{Binding SelectPaymentCommand}"
                    CommandParameter="{x:Static model:PaymentType.COD}"
                    HeightRequest="35"
                    Text="{Binding PaymentOptions[1].DisplayName}">
                    <Button.Triggers>
                        <DataTrigger
                            Binding="{Binding SelectedPaymentType}"
                            TargetType="Button"
                            Value="{x:Static model:PaymentType.COD}">
                            <Setter Property="BackgroundColor" Value="White" />
                            <Setter Property="TextColor" Value="Black" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding SelectedPaymentType}"
                            TargetType="Button"
                            Value="{x:Static model:PaymentType.Card}">
                            <Setter Property="BackgroundColor" Value="Transparent" />
                            <Setter Property="TextColor" Value="{StaticResource Gray400}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>
        </Border>
        <VerticalStackLayout
            Grid.Row="2"
            IsVisible="{Binding IsCardPaymentSelected}"
            Spacing="15"
            WidthRequest="390">
            <Label Text="Unesite podatke kartice" />
            <material:TextField
                Title="Ime vlasnika"
                AccentColor="Black"
                CornerRadius="20"
                WidthRequest="350" />
            <material:TextField
                Title="Broj kartice"
                AccentColor="Black"
                CornerRadius="20"
                WidthRequest="350" />
            <material:TextField
                Title="CVV kod"
                AccentColor="Black"
                CornerRadius="20"
                WidthRequest="350" />
            <material:TextField
                Title="Datum isteka (MM/GG)"
                AccentColor="Black"
                CornerRadius="20"
                WidthRequest="350" />
        </VerticalStackLayout>
        <VerticalStackLayout Grid.Row="3" Spacing="10">
            <Label
                Margin="0,0,40,0"
                HorizontalOptions="End"
                IsVisible="{Binding HasAnyAddresses}"
                Text="Promeni adresu"
                TextColor="{StaticResource Primary}">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ShowAddressSelectionCommand}" />
                </Label.GestureRecognizers>
            </Label>
            <Border
                IsVisible="{Binding HasAnyAddresses}"
                StrokeShape="RoundRectangle 20"
                WidthRequest="350">
                <VerticalStackLayout Padding="20">
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding SelectedAddress.City}" />
                        <Label Text="{Binding SelectedAddress.ZipCode}" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding SelectedAddress.Street}" />
                </VerticalStackLayout>
            </Border>

            <Label
                HorizontalOptions="Center"
                IsVisible="{Binding HasAnyAddresses, Converter={StaticResource InverseBooleanConverter}}"
                Text="Trenutno nemate nijednu sačuvanu adresu" />
            <Button
                BackgroundColor="{AppThemeBinding Light=Black,
                                                  Dark=White}"
                Clicked="AddAddress_Button_Clicked"
                IsVisible="{Binding HasAnyAddresses, Converter={StaticResource InverseBooleanConverter}}"
                Text="Dodaj adresu"
                TextColor="{AppThemeBinding Light=White,
                                            Dark=Black}"
                WidthRequest="350" />
        </VerticalStackLayout>
        <VerticalStackLayout
            Grid.Row="4"
            Margin="0,0,0,10"
            VerticalOptions="End">
            <VerticalStackLayout
                Grid.Row="4"
                Padding="20"
                VerticalOptions="End">
                <Grid>
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="{Binding CartQuantity}" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        HorizontalOptions="End"
                        Text="{Binding TotalPrice}" />
                </Grid>
                <Grid>
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="Dostava" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        HorizontalOptions="End"
                        Text="Besplatno" />
                </Grid>
                <Grid>
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        Text="Ukupno" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="16"
                        HorizontalOptions="End"
                        Text="{Binding TotalPrice}" />
                </Grid>
            </VerticalStackLayout>
            <BoxView
                Grid.Row="5"
                Grid.ColumnSpan="2"
                BackgroundColor="Black"
                HeightRequest="1"
                WidthRequest="370" />
            <Button
                Margin="0,10"
                BackgroundColor="{StaticResource Primary}"
                Clicked="Create_Order_Button_Clicked"
                CornerRadius="30"
                FontSize="16"
                StyleClass="ElevatedButton"
                Text="Kreiraj porudžbinu"
                TextColor="White"
                WidthRequest="350" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>